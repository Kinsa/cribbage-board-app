{
  "name": "cribbageboardapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "jest",
    "test:update": "jest -u",
    "coverage": "npm run test -- --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@kinsa/cribbage-board-app-tokens$": "<rootDir>/node_modules/@kinsa/cribbage-board-app-tokens/build/es/variables.mjs"
    },
    "transform": {
      "^.+\\.mjs$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|@kinsa/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-css-interop)/)"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --check",
      "eslint"
    ],
    "*.{json,md,css}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/vector-icons": "^15.0.3",
    "@kinsa/cribbage-board-app-tokens": "github:Kinsa/cribbage-board-app-tokens",
    "@testing-library/dom": "^10.4.1",
    "@types/aria-query": "^5.0.4",
    "ansi-styles": "^5.2.0",
    "aria-query": "^5.3.0",
    "dequal": "^2.0.3",
    "dom-accessibility-api": "^0.5.16",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-sensors": "15.0.8",
    "expo-splash-screen": "~31.0.13",
    "lz-string": "^1.5.0",
    "pretty-format": "^27.5.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-is": "^17.0.2",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/eslintrc": "^3.3.1",
    "@storybook/addon-a11y": "^10.1.4",
    "@storybook/addon-designs": "^11.1.0",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/addon-onboarding": "^10.1.4",
    "@storybook/addon-vitest": "^10.1.4",
    "@storybook/react-native-web-vite": "^10.1.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "babel-jest": "^30.2.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.1.4",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "lint-staged": "^16.1.6",
    "playwright": "^1.57.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.1.0",
    "storybook": "^10.1.4",
    "typescript": "~5.9.2",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  },
  "private": true
}
